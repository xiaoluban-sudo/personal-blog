---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  cover?: string;
  coverAlt?: string;
  category: string;
  tags: string[];
  pubDate: Date;
  readingTime: number;
  wordCount: number;
  draft: boolean;
  relatedPosts?: Array<{
    title: string;
    description: string;
    category: string;
    url: string;
  }>;
  previousPost?: {
    title: string;
    url: string;
  };
  nextPost?: {
    title: string;
    url: string;
  };
  headings: Array<{
    depth: number;
    slug: string;
    text: string;
  }>;
}

const {
  title,
  description,
  cover,
  coverAlt,
  category,
  tags,
  pubDate,
  readingTime,
  wordCount,
  draft,
  relatedPosts = [],
  previousPost,
  nextPost,
  headings
} = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const toc = headings.filter((heading) => heading.depth >= 2 && heading.depth <= 3);
const coverUrl = cover
  ? /^https?:\/\//.test(cover)
    ? cover
    : `${base}${cover.replace(/^\//, "")}`
  : undefined;
const formattedDate = new Intl.DateTimeFormat("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric"
}).format(pubDate);
---

<BaseLayout
  title={title}
  description={description}
  ogType="article"
  publishedTime={pubDate}
  tags={tags}
>
  <article class="post">
    <header class="post-header">
      <p class="post-date">
        <a href={`${base}categories/${encodeURIComponent(category)}/`}>{category}</a>
        <span aria-hidden="true">/</span>
        <time datetime={pubDate.toISOString()}>{formattedDate}</time>
        <span aria-hidden="true">/</span>
        <span>{readingTime} 分钟阅读</span>
        <span aria-hidden="true">/</span>
        <span>约 {wordCount} 字</span>
      </p>
      {draft && <span class="draft-badge">草稿预览</span>}
      <h1>{title}</h1>
      <p class="post-description">{description}</p>
      {
        tags.length > 0 && (
          <nav class="tag-list post-tags" aria-label="文章标签">
            {tags.map((tag) => (
              <a href={`${base}tags/${encodeURIComponent(tag)}/`}>#{tag}</a>
            ))}
          </nav>
        )
      }
      <button class="copy-link" type="button" data-copy-link>复制链接</button>
    </header>
    {
      coverUrl && (
        <figure class="post-cover">
          <img src={coverUrl} alt={coverAlt ?? ""} />
          {coverAlt && <figcaption>{coverAlt}</figcaption>}
        </figure>
      )
    }
    {
      toc.length > 1 && (
        <nav class="toc" aria-labelledby="toc-title">
          <h2 id="toc-title">目录</h2>
          <ol>
            {toc.map((heading) => (
              <li class={`toc-depth-${heading.depth}`}>
                <a href={`#${heading.slug}`}>{heading.text}</a>
              </li>
            ))}
          </ol>
        </nav>
      )
    }
    <div class="post-content">
      <slot />
    </div>
    {
      relatedPosts.length > 0 && (
        <section class="related-posts" aria-labelledby="related-posts-title">
          <h2 id="related-posts-title">相关文章</h2>
          <div class="related-post-list">
            {relatedPosts.map((relatedPost) => (
              <a href={relatedPost.url}>
                <span>{relatedPost.category}</span>
                <strong>{relatedPost.title}</strong>
                <p>{relatedPost.description}</p>
              </a>
            ))}
          </div>
        </section>
      )
    }
    {
      (previousPost || nextPost) && (
        <nav class="post-neighbors" aria-label="相邻文章">
          {previousPost ? (
            <a href={previousPost.url}>
              <span>上一篇</span>
              {previousPost.title}
            </a>
          ) : (
            <span />
          )}
          {nextPost ? (
            <a href={nextPost.url}>
              <span>下一篇</span>
              {nextPost.title}
            </a>
          ) : (
            <span />
          )}
        </nav>
      )
    }
  </article>
  <script is:inline define:vars={{ base }}>
    const basePath = base;
    const copyButton = document.querySelector("[data-copy-link]");

    document.querySelectorAll('.post-content img[src^="/"]').forEach((image) => {
      const source = image.getAttribute("src");

      if (source && !source.startsWith(basePath)) {
        image.setAttribute("src", `${basePath}${source.replace(/^\//, "")}`);
      }
    });

    copyButton?.addEventListener("click", async () => {
      const originalText = copyButton.textContent;

      try {
        await navigator.clipboard.writeText(window.location.href);
        copyButton.textContent = "已复制";
      } catch {
        copyButton.textContent = "复制失败";
      }

      window.setTimeout(() => {
        copyButton.textContent = originalText;
      }, 1400);
    });
  </script>
</BaseLayout>
