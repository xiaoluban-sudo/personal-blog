---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "一个从零开始慢慢生长的个人博客。" } = Astro.props;
const pageTitle = title === "首页" ? "我的博客" : `${title} - 我的博客`;
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;
const rssUrl = `${base}rss.xml`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <link rel="alternate" type="application/rss+xml" title="我的博客 RSS" href={rssUrl} />
    <link rel="stylesheet" href={`${base}styles/global.css`} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>我的博客</a>
      <nav aria-label="主导航">
        <a href={base}>文章</a>
        <a href={`${base}about/`}>关于</a>
        <a href={rssUrl}>RSS</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
