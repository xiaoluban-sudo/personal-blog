---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="写作" description="本地 Markdown 写作工作台。">
  <section class="write-page" aria-labelledby="write-title">
    <header class="write-header">
      <div>
        <p class="eyebrow">Writing Desk</p>
        <h1 id="write-title">写作工作台</h1>
      </div>
      <div class="write-actions">
        <button type="button" data-copy-post>复制全文</button>
        <button type="button" data-download-post>下载 Markdown</button>
        <button type="button" data-reset-draft>清空</button>
      </div>
    </header>

    <div class="write-shell">
      <form class="write-form" data-write-form>
        <section class="write-panel" aria-labelledby="import-title">
          <h2 id="import-title">导入文章</h2>
          <label>
            <span>选择 .md 文件继续编辑</span>
            <input data-import-post type="file" accept=".md,text/markdown,text/plain" />
          </label>
        </section>

        <label>
          <span>标题</span>
          <input name="title" type="text" value="新的博客文章" />
        </label>
        <label>
          <span>简介</span>
          <input name="description" type="text" value="这里写一句文章简介。" />
        </label>
        <div class="write-fields">
          <label>
            <span>分类</span>
            <input name="category" type="text" value="随记" />
          </label>
          <label>
            <span>标签</span>
            <input name="tags" type="text" placeholder="Astro,博客" />
          </label>
        </div>
        <div class="write-fields">
          <label>
            <span>日期</span>
            <input name="pubDate" type="date" />
          </label>
          <label class="write-checkbox">
            <input name="draft" type="checkbox" />
            <span>保存为草稿</span>
          </label>
        </div>
        <label>
          <span>封面图</span>
          <input name="cover" type="text" placeholder="/images/covers/post.svg" />
        </label>
        <label>
          <span>封面描述</span>
          <input name="coverAlt" type="text" placeholder="描述这张封面图" />
        </label>
        <section class="write-panel" aria-labelledby="image-helper-title">
          <h2 id="image-helper-title">图片路径辅助</h2>
          <label>
            <span>选择图片文件名</span>
            <input data-image-file type="file" accept="image/*" />
          </label>
          <div class="write-fields">
            <label>
              <span>图片目录</span>
              <input data-image-folder type="text" value="/images/posts/" />
            </label>
            <label>
              <span>图片描述</span>
              <input data-image-alt type="text" placeholder="图片说明" />
            </label>
          </div>
          <div class="image-helper-actions">
            <code data-image-path>/images/posts/example.png</code>
            <button type="button" data-insert-image-path>插入图片语法</button>
          </div>
          <p>
            静态站不会直接上传图片。把图片放进项目的
            <code>public/images/posts/</code> 后，再使用这里生成的路径。
          </p>
        </section>
        <label class="write-editor">
          <span>正文</span>
          <div class="markdown-toolbar" aria-label="Markdown 快捷插入">
            <button type="button" data-insert-markdown="heading">标题</button>
            <button type="button" data-insert-markdown="bold">加粗</button>
            <button type="button" data-insert-markdown="link">链接</button>
            <button type="button" data-insert-markdown="image">图片</button>
            <button type="button" data-insert-markdown="quote">引用</button>
            <button type="button" data-insert-markdown="code">代码块</button>
            <button type="button" data-insert-markdown="table">表格</button>
          </div>
          <textarea name="body" spellcheck="false">## 小标题

从这里开始写正文。

- 可以写列表
- 可以写代码
- 可以一点点打磨
</textarea>
        </label>
      </form>

      <aside class="write-preview" aria-labelledby="preview-title">
        <div class="write-preview-toolbar">
          <h2 id="preview-title">实时预览</h2>
          <p data-copy-status aria-live="polite"></p>
        </div>
        <article class="post-content" data-preview></article>
        <section class="publish-checklist" aria-labelledby="publish-checklist-title">
          <div class="publish-checklist-header">
            <h2 id="publish-checklist-title">发布清单</h2>
            <p data-publish-summary></p>
          </div>
          <ul data-publish-checklist></ul>
        </section>
        <details class="write-output">
          <summary>生成的 Markdown</summary>
          <pre><code data-output></code></pre>
        </details>
        <details class="markdown-help" open>
          <summary>Markdown 速查</summary>
          <div class="markdown-help-grid">
            <code>## 二级标题</code>
            <code>**加粗**</code>
            <code>*斜体*</code>
            <code>- 无序列表</code>
            <code>1. 有序列表</code>
            <code>[链接](https://example.com)</code>
            <code>![图片描述](/images/example.png)</code>
            <code>&gt; 引用</code>
            <code>`行内代码`</code>
            <code>```js<br />console.log("hello");<br />```</code>
            <code>---</code>
            <code>| 名称 | 说明 |<br />| --- | --- |</code>
          </div>
        </details>
        <details class="draft-help" open>
          <summary>草稿管理说明</summary>
          <ul>
            <li>工作台内容会自动保存在当前浏览器的本地存储里。</li>
            <li>刷新页面不会丢内容；换浏览器或换电脑不会同步。</li>
            <li>下载的 `.md` 文件放进 <code>src/content/posts/</code> 后，就能进入博客内容流。</li>
            <li>勾选“保存为草稿”会生成 <code>draft: true</code>，本地可预览，生产部署会隐藏。</li>
          </ul>
        </details>
      </aside>
    </div>
  </section>

  <script>
    // @ts-nocheck
    import { marked } from "marked";

    const form = document.querySelector("[data-write-form]");
    const preview = document.querySelector("[data-preview]");
    const output = document.querySelector("[data-output]");
    const publishSummary = document.querySelector("[data-publish-summary]");
    const publishChecklist = document.querySelector("[data-publish-checklist]");
    const copyButton = document.querySelector("[data-copy-post]");
    const downloadButton = document.querySelector("[data-download-post]");
    const resetButton = document.querySelector("[data-reset-draft]");
    const status = document.querySelector("[data-copy-status]");
    const markdownButtons = document.querySelectorAll("[data-insert-markdown]");
    const importInput = document.querySelector("[data-import-post]");
    const imageFileInput = document.querySelector("[data-image-file]");
    const imageFolderInput = document.querySelector("[data-image-folder]");
    const imageAltInput = document.querySelector("[data-image-alt]");
    const imagePath = document.querySelector("[data-image-path]");
    const insertImagePathButton = document.querySelector("[data-insert-image-path]");
    const storageKey = "personal-blog-write-draft";

    if (
      !(form instanceof HTMLFormElement) ||
      !(preview instanceof HTMLElement) ||
      !(output instanceof HTMLElement) ||
      !(publishSummary instanceof HTMLElement) ||
      !(publishChecklist instanceof HTMLElement) ||
      !(copyButton instanceof HTMLButtonElement) ||
      !(downloadButton instanceof HTMLButtonElement) ||
      !(resetButton instanceof HTMLButtonElement) ||
      !(status instanceof HTMLElement) ||
      !(importInput instanceof HTMLInputElement) ||
      !(imageFileInput instanceof HTMLInputElement) ||
      !(imageFolderInput instanceof HTMLInputElement) ||
      !(imageAltInput instanceof HTMLInputElement) ||
      !(imagePath instanceof HTMLElement) ||
      !(insertImagePathButton instanceof HTMLButtonElement)
    ) {
      throw new Error("Write page is missing required elements.");
    }

    const fields = {
      title: form.elements.namedItem("title"),
      description: form.elements.namedItem("description"),
      category: form.elements.namedItem("category"),
      tags: form.elements.namedItem("tags"),
      pubDate: form.elements.namedItem("pubDate"),
      draft: form.elements.namedItem("draft"),
      cover: form.elements.namedItem("cover"),
      coverAlt: form.elements.namedItem("coverAlt"),
      body: form.elements.namedItem("body")
    };

    function isInput(field) {
      return field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement;
    }

    function getValue(name) {
      const field = fields[name];
      return isInput(field) ? field.value.trim() : "";
    }

    function setValue(name, value) {
      const field = fields[name];
      if (isInput(field)) field.value = value;
    }

    function getDraftValue() {
      return fields.draft instanceof HTMLInputElement && fields.draft.checked;
    }

    function setDraftValue(value) {
      if (fields.draft instanceof HTMLInputElement) fields.draft.checked = value;
    }

    function getBodyField() {
      return fields.body instanceof HTMLTextAreaElement ? fields.body : undefined;
    }

    function today() {
      return new Date().toISOString().slice(0, 10);
    }

    function escapeYaml(value) {
      return value.replace(/\\/g, "\\\\").replace(/"/g, '\\"');
    }

    function toSlug(value) {
      const slug = value
        .normalize("NFKD")
        .toLowerCase()
        .replace(/[^\p{Letter}\p{Number}]+/gu, "-")
        .replace(/^-+|-+$/g, "");

      return slug || "post";
    }

    function formatTags(value) {
      const tags = value
        .split(",")
        .map((tag) => tag.trim())
        .filter(Boolean);

      return `[${tags.map((tag) => `"${escapeYaml(tag)}"`).join(", ")}]`;
    }

    function buildMarkdown() {
      const cover = getValue("cover");
      const coverAlt = getValue("coverAlt");
      const coverFields = cover
        ? `cover: "${escapeYaml(cover)}"\ncoverAlt: "${escapeYaml(coverAlt)}"\n`
        : "";

      return `---
title: "${escapeYaml(getValue("title") || "未命名文章")}"
description: "${escapeYaml(getValue("description") || "暂无简介。")}"
${coverFields}category: "${escapeYaml(getValue("category") || "随记")}"
tags: ${formatTags(getValue("tags"))}
pubDate: "${getValue("pubDate") || today()}"
draft: ${getDraftValue()}
---

${getValue("body") || "从这里开始写正文。"}`;
    }

    function parseYamlValue(value) {
      const trimmed = value.trim();

      if (trimmed === "true") return true;
      if (trimmed === "false") return false;
      if (trimmed.startsWith("[") && trimmed.endsWith("]")) {
        return trimmed
          .slice(1, -1)
          .split(",")
          .map((item) => item.trim().replace(/^["']|["']$/g, ""))
          .filter(Boolean);
      }

      return trimmed.replace(/^["']|["']$/g, "");
    }

    function importMarkdown(markdown) {
      const match = markdown.match(/^---\n([\s\S]*?)\n---\n?([\s\S]*)$/);

      if (!match) {
        setValue("body", markdown);
        render();
        return;
      }

      const frontmatter = Object.fromEntries(
        match[1]
          .split("\n")
          .map((line) => line.match(/^([A-Za-z]+):\s*(.*)$/))
          .filter(Boolean)
          .map((lineMatch) => [lineMatch[1], parseYamlValue(lineMatch[2])])
      );

      setValue("title", String(frontmatter.title ?? "新的博客文章"));
      setValue("description", String(frontmatter.description ?? "这里写一句文章简介。"));
      setValue("category", String(frontmatter.category ?? "随记"));
      setValue("tags", Array.isArray(frontmatter.tags) ? frontmatter.tags.join(",") : "");
      setValue("pubDate", String(frontmatter.pubDate ?? today()));
      setValue("cover", String(frontmatter.cover ?? ""));
      setValue("coverAlt", String(frontmatter.coverAlt ?? ""));
      setDraftValue(Boolean(frontmatter.draft));
      setValue("body", match[2].trim());
      render();
    }

    function sanitizeHtml(html) {
      const documentFragment = new DOMParser().parseFromString(html, "text/html");
      documentFragment
        .querySelectorAll("script, style, iframe, object, embed")
        .forEach((node) => node.remove());

      documentFragment.body.querySelectorAll("*").forEach((node) => {
        [...node.attributes].forEach((attribute) => {
          const name = attribute.name.toLowerCase();
          const value = attribute.value.trim().toLowerCase();

          if (name.startsWith("on") || value.startsWith("javascript:")) {
            node.removeAttribute(attribute.name);
          }
        });
      });

      return documentFragment.body.innerHTML;
    }

    function hasBodyImages(body) {
      return /!\[[^\]]*\]\(([^)]+)\)/.test(body);
    }

    function isDefaultBody(body) {
      return body.includes("从这里开始写正文。") && body.length < 80;
    }

    function renderPublishChecklist() {
      const title = getValue("title");
      const description = getValue("description");
      const category = getValue("category");
      const pubDate = getValue("pubDate");
      const body = getValue("body");
      const cover = getValue("cover");
      const isDraft = getDraftValue();
      const bodyUsesImages = hasBodyImages(body);
      const checks = [
        {
          ok: Boolean(title),
          text: "标题已填写"
        },
        {
          ok: Boolean(description),
          text: "简介已填写"
        },
        {
          ok: Boolean(category),
          text: "分类已填写"
        },
        {
          ok: Boolean(pubDate),
          text: "发布日期已填写"
        },
        {
          ok: Boolean(body) && !isDefaultBody(body),
          text: "正文已经替换默认占位内容"
        },
        {
          ok: !cover || cover.startsWith("http") || cover.startsWith("/images/covers/"),
          text: cover
            ? "封面路径建议放在 public/images/covers/"
            : "没有封面图，可以跳过封面检查"
        },
        {
          ok: !bodyUsesImages,
          text: bodyUsesImages
            ? "正文里有图片，发布前确认图片已放入 public/images/posts/"
            : "正文暂未使用图片"
        },
        {
          ok: isDraft,
          text: isDraft
            ? "当前是草稿，本地可预览，生产部署会隐藏"
            : "当前不是草稿，下载后可放入 src/content/posts/ 发布"
        },
        {
          ok: false,
          text: "最后执行 git add、git commit、git push 触发部署"
        }
      ];
      const readyCount = checks.filter((check) => check.ok).length;

      publishSummary.textContent = `${readyCount}/${checks.length} 项已就绪`;
      publishChecklist.innerHTML = checks
        .map(
          (check) => `
            <li data-ready="${check.ok}">
              <span aria-hidden="true">${check.ok ? "✓" : "•"}</span>
              ${check.text}
            </li>
          `
        )
        .join("");
    }

    function saveDraft() {
      const data = Object.fromEntries(
        Object.entries(fields).map(([name, field]) => [
          name,
          field instanceof HTMLInputElement && field.type === "checkbox"
            ? field.checked
            : isInput(field)
              ? field.value
              : ""
        ])
      );
      localStorage.setItem(storageKey, JSON.stringify(data));
    }

    function loadDraft() {
      const saved = localStorage.getItem(storageKey);
      if (!saved) {
        setValue("pubDate", today());
        return;
      }

      try {
        const data = JSON.parse(saved);
        Object.entries(data).forEach(([name, value]) => {
          if (name === "draft") setDraftValue(Boolean(value));
          else setValue(name, String(value ?? ""));
        });
      } catch {
        setValue("pubDate", today());
      }
    }

    function render() {
      const body = getValue("body") || "从这里开始写正文。";
      output.textContent = buildMarkdown();
      preview.innerHTML = sanitizeHtml(marked.parse(body, { async: false }));
      renderPublishChecklist();
      saveDraft();
    }

    function downloadMarkdown() {
      const markdown = buildMarkdown();
      const filename = `${toSlug(getValue("title") || "post")}.md`;
      const blob = new Blob([markdown], { type: "text/markdown;charset=utf-8" });
      const url = URL.createObjectURL(blob);
      const link = document.createElement("a");
      link.href = url;
      link.download = filename;
      link.click();
      URL.revokeObjectURL(url);
      status.textContent = `已下载 ${filename}`;
      window.setTimeout(() => {
        status.textContent = "";
      }, 1800);
    }

    function normalizeFolder(value) {
      const folder = value.trim() || "/images/posts/";
      return `/${folder.replace(/^\/+/, "").replace(/\/?$/, "/")}`;
    }

    function syncImagePath() {
      const file = imageFileInput.files?.[0];
      const filename = file?.name || "example.png";
      imagePath.textContent = `${normalizeFolder(imageFolderInput.value)}${filename}`;
    }

    function insertImageMarkdown() {
      const bodyField = getBodyField();
      if (!bodyField) return;

      const alt = imageAltInput.value.trim() || "图片描述";
      const snippet = `![${alt}](${imagePath.textContent})`;
      const start = bodyField.selectionStart;
      const end = bodyField.selectionEnd;
      bodyField.value = `${bodyField.value.slice(0, start)}${snippet}${bodyField.value.slice(end)}`;
      bodyField.focus();
      bodyField.selectionStart = start + snippet.length;
      bodyField.selectionEnd = start + snippet.length;
      render();
    }

    const snippets = {
      heading: "## 小标题\n\n",
      bold: "**加粗文字**",
      link: "[链接文字](https://example.com)",
      image: "![图片描述](/images/example.png)",
      quote: "> 这里写引用内容\n\n",
      code: "```js\nconsole.log(\"hello\");\n```\n\n",
      table: "| 名称 | 说明 |\n| --- | --- |\n| Astro | 静态站点框架 |\n\n"
    };

    function insertMarkdown(type) {
      const bodyField = getBodyField();
      const snippet = snippets[type];

      if (!bodyField || !snippet) return;

      const start = bodyField.selectionStart;
      const end = bodyField.selectionEnd;
      const before = bodyField.value.slice(0, start);
      const after = bodyField.value.slice(end);
      bodyField.value = `${before}${snippet}${after}`;
      bodyField.focus();
      bodyField.selectionStart = start + snippet.length;
      bodyField.selectionEnd = start + snippet.length;
      render();
    }

    form.addEventListener("input", render);

    markdownButtons.forEach((button) => {
      button.addEventListener("click", () => {
        if (button instanceof HTMLButtonElement) {
          insertMarkdown(button.dataset.insertMarkdown);
        }
      });
    });

    copyButton.addEventListener("click", async () => {
      await navigator.clipboard.writeText(buildMarkdown());
      status.textContent = "已复制";
      window.setTimeout(() => {
        status.textContent = "";
      }, 1400);
    });

    downloadButton.addEventListener("click", downloadMarkdown);

    importInput.addEventListener("change", async () => {
      const file = importInput.files?.[0];
      if (!file) return;

      importMarkdown(await file.text());
      status.textContent = `已导入 ${file.name}`;
      window.setTimeout(() => {
        status.textContent = "";
      }, 1800);
    });

    imageFileInput.addEventListener("change", syncImagePath);
    imageFolderInput.addEventListener("input", syncImagePath);
    insertImagePathButton.addEventListener("click", insertImageMarkdown);

    resetButton.addEventListener("click", () => {
      localStorage.removeItem(storageKey);
      form.reset();
      setValue("title", "新的博客文章");
      setValue("description", "这里写一句文章简介。");
      setValue("category", "随记");
      setValue("pubDate", today());
      render();
    });

    loadDraft();
    syncImagePath();
    render();
  </script>
</BaseLayout>
