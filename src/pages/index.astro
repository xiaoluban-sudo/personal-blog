---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getVisiblePosts, showDrafts } from "../lib/posts";

const posts = await getVisiblePosts();
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const categories = [...new Set(posts.map((post) => post.data.category))];
const tags = [...new Set(posts.flatMap((post) => post.data.tags))];

function getCoverUrl(cover: string) {
  if (/^https?:\/\//.test(cover)) return cover;
  return `${base}${cover.replace(/^\//, "")}`;
}

function getReadingTime(body: string) {
  const words = body.trim().split(/\s+/).filter(Boolean).length;
  const characters = body.replace(/\s/g, "").length;
  return Math.max(1, Math.ceil(Math.max(words / 220, characters / 500)));
}
---

<BaseLayout title="首页">
  <section class="intro">
    <p class="eyebrow">Personal Blog</p>
    <h1>记录想法、代码和一路迭代的过程。</h1>
    <p>
      这里会放我的文章、项目笔记，以及这个博客从第一版慢慢长出来的每一步。
    </p>
  </section>

  <section class="post-list" aria-labelledby="posts-title">
    <h2 id="posts-title">最新文章</h2>
    {
      categories.length > 0 && (
        <nav class="category-nav" aria-label="文章分类">
          {categories.map((category) => (
            <a href={`${base}categories/${encodeURIComponent(category)}/`}>
              {category}
            </a>
          ))}
        </nav>
      )
    }
    {
      tags.length > 0 && (
        <nav class="tag-list home-tags" aria-label="文章标签">
          {tags.map((tag) => (
            <a href={`${base}tags/${encodeURIComponent(tag)}/`}>#{tag}</a>
          ))}
        </nav>
      )
    }
    {
      posts.length > 0 ? (
        <ul>
          {posts.map((post) => (
            <li>
              {
                post.data.cover && (
                  <a class="post-card-cover" href={`${base}posts/${post.slug}/`}>
                    <img
                      src={getCoverUrl(post.data.cover)}
                      alt={post.data.coverAlt ?? ""}
                      loading="lazy"
                    />
                  </a>
                )
              }
              <a href={`${base}posts/${post.slug}/`}>
                <span>{post.data.title}{post.data.draft && "（草稿）"}</span>
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString("zh-CN")} / {getReadingTime(post.body)} 分钟
                </time>
              </a>
              <a
                class="post-category"
                href={`${base}categories/${encodeURIComponent(post.data.category)}/`}
              >
                {post.data.category}
              </a>
              {
                post.data.tags.length > 0 && (
                  <nav class="tag-list post-card-tags" aria-label={`${post.data.title} 的标签`}>
                    {post.data.tags.map((tag) => (
                      <a href={`${base}tags/${encodeURIComponent(tag)}/`}>#{tag}</a>
                    ))}
                  </nav>
                )
              }
              {post.data.draft && <span class="draft-badge">草稿</span>}
              <p>{post.data.description}</p>
            </li>
          ))}
        </ul>
      ) : (
        <p>还没有文章。</p>
      )
    }
    {showDrafts && <p class="draft-note">本地开发模式正在显示草稿文章，生产构建会自动隐藏。</p>}
  </section>
</BaseLayout>
