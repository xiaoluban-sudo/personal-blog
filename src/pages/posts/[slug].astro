---
import { getCollection, render } from "astro:content";
import PostLayout from "../../layouts/PostLayout.astro";
import { showDrafts } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = (await getCollection("posts"))
    .filter((post) => showDrafts || !post.data.draft)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  const base = import.meta.env.BASE_URL.endsWith("/")
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;

  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      post,
      relatedPosts: posts
        .filter((candidate) => candidate.slug !== post.slug)
        .map((candidate) => {
          const sharedTags = candidate.data.tags.filter((tag) =>
            post.data.tags.includes(tag)
          ).length;
          const score =
            (candidate.data.category === post.data.category ? 3 : 0) +
            sharedTags * 2;

          return { candidate, score };
        })
        .filter(({ score }) => score > 0)
        .sort((a, b) => {
          if (b.score !== a.score) return b.score - a.score;
          return (
            b.candidate.data.pubDate.valueOf() -
            a.candidate.data.pubDate.valueOf()
          );
        })
        .slice(0, 3)
        .map(({ candidate }) => ({
          title: candidate.data.title,
          description: candidate.data.description,
          category: candidate.data.category,
          url: `${base}posts/${candidate.slug}/`
        })),
      previousPost: posts[index + 1]
        ? {
            title: posts[index + 1].data.title,
            url: `${base}posts/${posts[index + 1].slug}/`
          }
        : undefined,
      nextPost: posts[index - 1]
        ? {
            title: posts[index - 1].data.title,
            url: `${base}posts/${posts[index - 1].slug}/`
          }
        : undefined
    }
  }));
}

const { post, relatedPosts, previousPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);

function getReadingTime(body: string) {
  const words = body.trim().split(/\s+/).filter(Boolean).length;
  const characters = body.replace(/\s/g, "").length;
  return Math.max(1, Math.ceil(Math.max(words / 220, characters / 500)));
}

function getWordCount(body: string) {
  return body.replace(/\s/g, "").length;
}
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  cover={post.data.cover}
  coverAlt={post.data.coverAlt}
  category={post.data.category}
  tags={post.data.tags}
  pubDate={post.data.pubDate}
  readingTime={getReadingTime(post.body)}
  wordCount={getWordCount(post.body)}
  draft={post.data.draft}
  relatedPosts={relatedPosts}
  previousPost={previousPost}
  nextPost={nextPost}
  headings={headings}
>
  <Content />
</PostLayout>
