---
import { getCollection, render } from "astro:content";
import PostLayout from "../../layouts/PostLayout.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );
  const base = import.meta.env.BASE_URL.endsWith("/")
    ? import.meta.env.BASE_URL
    : `${import.meta.env.BASE_URL}/`;

  return posts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      post,
      previousPost: posts[index + 1]
        ? {
            title: posts[index + 1].data.title,
            url: `${base}posts/${posts[index + 1].slug}/`
          }
        : undefined,
      nextPost: posts[index - 1]
        ? {
            title: posts[index - 1].data.title,
            url: `${base}posts/${posts[index - 1].slug}/`
          }
        : undefined
    }
  }));
}

const { post, previousPost, nextPost } = Astro.props;
const { Content, headings } = await render(post);

function getReadingTime(body: string) {
  const words = body.trim().split(/\s+/).filter(Boolean).length;
  const characters = body.replace(/\s/g, "").length;
  return Math.max(1, Math.ceil(Math.max(words / 220, characters / 500)));
}

function getWordCount(body: string) {
  return body.replace(/\s/g, "").length;
}
---

<PostLayout
  title={post.data.title}
  description={post.data.description}
  category={post.data.category}
  tags={post.data.tags}
  pubDate={post.data.pubDate}
  readingTime={getReadingTime(post.body)}
  wordCount={getWordCount(post.body)}
  previousPost={previousPost}
  nextPost={nextPost}
  headings={headings}
>
  <Content />
</PostLayout>
