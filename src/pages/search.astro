---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getVisiblePosts } from "../lib/posts";

const posts = await getVisiblePosts();
const base = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const searchIndex = posts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  category: post.data.category,
  tags: post.data.tags,
  draft: post.data.draft,
  date: post.data.pubDate.toLocaleDateString("zh-CN"),
  url: `${base}posts/${post.slug}/`,
  body: post.body
    .replace(/^---[\s\S]*?---/, "")
    .replace(/[`*_#[\]()]/g, " ")
    .replace(/\s+/g, " ")
    .trim(),
  text: [
    post.data.title,
    post.data.description,
    post.data.category,
    ...post.data.tags,
    post.body
  ]
    .join(" ")
    .toLowerCase()
}));
---

<BaseLayout title="搜索" description="搜索博客文章。">
  <section class="page search-page">
    <p class="eyebrow">Search</p>
    <h1>搜索文章</h1>
    <label class="search-box">
      <span>关键词</span>
      <input
        id="search-input"
        type="search"
        autocomplete="off"
        placeholder="搜索标题、正文、简介、分类或标签"
      />
    </label>
    <p id="search-count" class="search-count"></p>
  </section>

  <section class="post-list search-results" aria-labelledby="search-results-title">
    <h2 id="search-results-title">结果</h2>
    <ul id="search-results-list"></ul>
  </section>

  <script id="search-index" type="application/json" is:inline set:html={JSON.stringify(searchIndex)} />
  <script is:inline>
    // @ts-nocheck
    /**
     * @typedef {{
     *   title: string;
     *   description: string;
    *   category: string;
    *   tags: string[];
     *   draft: boolean;
     *   date: string;
     *   url: string;
     *   body: string;
     *   text: string;
     * }} SearchPost
     */

    const input = document.querySelector("#search-input");
    const count = document.querySelector("#search-count");
    const list = document.querySelector("#search-results-list");
    const dataNode = document.querySelector("#search-index");

    if (!(input instanceof HTMLInputElement) || !count || !list || !dataNode) {
      throw new Error("Search page is missing required elements.");
    }

    /** @type {SearchPost[]} */
    const posts = JSON.parse(dataNode.textContent || "[]");

    /** @param {string} value */
    function escapeHtml(value) {
      return value.replace(/[&<>"']/g, (character) => {
        /** @type {Record<string, string>} */
        const entities = {
          "&": "&amp;",
          "<": "&lt;",
          ">": "&gt;",
          '"': "&quot;",
          "'": "&#039;"
        };

        return entities[character];
      });
    }

    /**
     * @param {SearchPost[]} results
     * @param {string} query
     */
    function render(results, query) {
      count.textContent = query
        ? `找到 ${results.length} 篇文章`
        : `共有 ${posts.length} 篇文章`;

      list.innerHTML = results
        .map((post) => {
          const tags = post.tags
            .map((tag) => `<span>#${escapeHtml(tag)}</span>`)
            .join("");
          const snippet = getSnippet(post, query);

          return `<li>
            <a href="${post.url}">
              <span>${escapeHtml(post.title)}${post.draft ? "（草稿）" : ""}</span>
              <time>${escapeHtml(post.date)}</time>
            </a>
            <div class="search-meta">
              <span>${escapeHtml(post.category)}</span>${post.draft ? "<span>草稿</span>" : ""}${tags}
            </div>
            <p>${escapeHtml(snippet || post.description)}</p>
          </li>`;
        })
        .join("");
    }

    function getSnippet(post, query) {
      if (!query) {
        return "";
      }

      const keywords = query.split(/\s+/).filter(Boolean);
      const text = post.body || post.description;
      const lowerText = text.toLowerCase();
      const position = keywords
        .map((keyword) => lowerText.indexOf(keyword))
        .filter((index) => index >= 0)
        .sort((a, b) => a - b)[0];

      if (position === undefined) {
        return post.description;
      }

      const start = Math.max(0, position - 28);
      const end = Math.min(text.length, position + 72);
      const prefix = start > 0 ? "..." : "";
      const suffix = end < text.length ? "..." : "";

      return `${prefix}${text.slice(start, end)}${suffix}`;
    }

    function search() {
      const query = input.value.trim().toLowerCase();
      const keywords = query.split(/\s+/).filter(Boolean);
      const results = keywords.length
        ? posts.filter((post) => keywords.every((keyword) => post.text.includes(keyword)))
        : posts;

      render(results, query);
    }

    input.addEventListener("input", search);
    render(posts, "");
  </script>
</BaseLayout>
